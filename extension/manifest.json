{
  "manifest_version": 3,
  "name": "newtab.party",
  "version": "1.1.0",
  "description": "newtab.party — a different arcade game every day, shared leaderboard, no extension update needed to add games.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://newtab-party.workers.dev http://localhost:8787;"
  },
  "host_permissions": ["https://newtab.party/*", "http://localhost:8787/*"]
}

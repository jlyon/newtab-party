{
  "manifest_version": 3,
  "name": "newtab.party",
  "version": "1.2.0",
  "description": "A new arcade game every day. Built by AI, played by humans, judged by the leaderboard. Every new tab, a justifiable distraction.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://newtab.party http://localhost:8787;"
  },
  "host_permissions": ["https://newtab.party/*", "http://localhost:8787/*"]
}
